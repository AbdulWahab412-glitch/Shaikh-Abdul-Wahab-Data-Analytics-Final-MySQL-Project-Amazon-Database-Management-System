-- Use Amazon Database management System

use amazon;

-- Drop database if needed

drop database amazon;

/*
Analyzing Amazon Database managenment system
by writting queries
*/

/*
=========================================
1. Customers table
========================================
*/

-- Retrieve all data from the Customer table
select* from customers;

-- Select a customer name column from the table 
select name
from customers;

-- Select name along with email of the customer
select name, email
from customers;

-- Select strating 4 customers
select * from customers limit 4;

-- select ending four customers
select * from customers limit 4 offset 6;

-- select in Descending order name
select * from customers order by name desc;

-- select customer in mumbai city
select * from customers 
where city = "Mumbai";

-- Select Specific email of the customer
select customer_id, email
from customers where email = "aman@gmail.com";

-- select Customer with phone numner
select customer_id, phone from customers;

-- Select Customer with a name strating with A
SELECT * FROM customers WHERE name LIKE 'A%';

/*
========================================
2. Seller Table
=======================================
*/

-- retrieve all records from the tabkle
select * from sellers;

-- Select individuals column from the table
SELECT name, city FROM sellers;

-- Select seller with Highest rating
SELECT * FROM sellers WHERE rating > 4.5;

-- Select sellers from the Delhi location
SELECT * FROM sellers WHERE city='Delhi';

-- Select rating from Highest to lowest
SELECT * FROM sellers ORDER BY rating DESC;

-- Count total sellers;
SELECT COUNT(*) FROM sellers;

-- Select unique city from the seller table
SELECT DISTINCT city FROM sellers;

-- Select where  seller name is SellerA
SELECT * FROM sellers WHERE name LIKE 'SellerA%';

-- Show contact information  for Seller id 2.
SELECT contact FROM sellers WHERE seller_id=2;

-- Sellect Average rating from the seller.
SELECT AVG(rating) FROM sellers;

